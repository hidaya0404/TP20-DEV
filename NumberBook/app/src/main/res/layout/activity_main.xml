<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FDF2F8"
    android:padding="16dp"
    tools:context=".MainActivity">

    <!-- Titre de l'application -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Number Book"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#7B1FA2"
        android:gravity="center"
        android:layout_marginBottom="6dp" />

    <!-- Description courte -->
    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gestion et synchronisation des contacts"
        android:textSize="14sp"
        android:textColor="#6A1B9A"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <!-- Zone des boutons principaux -->
    <LinearLayout
        android:id="@+id/buttonsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnLoadContacts"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Lire contacts"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#EC407A"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnSyncContacts"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Synchroniser"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#AB47BC"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- Zone de recherche -->
    <LinearLayout
        android:id="@+id/searchLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <EditText
            android:id="@+id/etKeyword"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Nom ou numéro"
            android:inputType="text"
            android:padding="12dp"
            android:textColor="#212121"
            android:textColorHint="#9E9E9E"
            android:backgroundTint="#CE93D8" />

        <Button
            android:id="@+id/btnSearch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chercher"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#8E24AA"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- Texte d'information -->
    <TextView
        android:id="@+id/tvInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Liste des contacts"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#4A148C"
        android:layout_marginBottom="8dp" />

    <!-- RecyclerView pour afficher les contacts -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewContacts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF"
        android:padding="8dp" />

</LinearLayout>